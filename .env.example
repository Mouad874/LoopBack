# ==============================================================================
# LoopBack — Social Media Autopilot Environment Template
# ==============================================================================
# Rename this file to .env and fill in your actual credentials.
# NEVER commit your actual .env file with real secrets to git/GitHub.

# ── Qwen DashScope API Key (REQUIRED) ─────────────────────────────────────────
# Get yours at: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ── Qwen Model Selection (Optional — defaults shown) ──────────────────────────
# Primary model used for all triage classifications (higher quality).
QWEN_PRIMARY_MODEL=qwen-plus
# Fallback model used if primary fails after retries (cheaper, still capable).
QWEN_FALLBACK_MODEL=qwen-turbo

# ── Webhook Security (REQUIRED for production) ────────────────────────────────
# A secret token used to authenticate inbound webhook calls.
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
# Used as X-Webhook-Secret header (static auth) or HMAC-SHA256 signing secret.
# WARNING: If unset, webhook authentication is DISABLED.
WEBHOOK_SECRET=your_strong_random_secret_here

# ── Webhook / Poller URLs (Optional) ──────────────────────────────────────────
# URL where the webhook server is running (used by social_poller.py)
WEBHOOK_URL=http://localhost:8001/webhook/social
# Polling interval in seconds for social_poller.py continuous mode
POLL_INTERVAL=60

# ── Instagram Graph API (Optional — for live social polling) ──────────────────
# 1. Create a Business app at https://developers.facebook.com/
# 2. Add Instagram Graph API product
# 3. Generate a long-lived User Access Token with instagram_basic, instagram_manage_comments
INSTAGRAM_ACCESS_TOKEN=your_instagram_long_lived_token_here
INSTAGRAM_USER_ID=your_numeric_instagram_user_id_here

# ── TikTok Developer API (Optional — for live social polling) ─────────────────
# 1. Create an app at https://developers.tiktok.com/
# 2. Add Display API scope and authorize
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
